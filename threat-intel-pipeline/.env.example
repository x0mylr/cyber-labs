# Threat Intelligence Pipeline — Environment Variables
# =====================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
#
# Load with: export $(cat .env | xargs)
# Or use docker-compose which reads .env automatically.

# ── Required for AI analysis ────────────────────────────────────────
# Get your key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# ── Optional API keys (enable additional collectors/enrichment) ──────

# AlienVault OTX (free): https://otx.alienvault.com/
# Auto-enables the OTX collector when set.
OTX_API_KEY=

# VirusTotal (free tier — 1000 lookups/day): https://www.virustotal.com/
# Enables hash enrichment via VirusTotal.
VT_API_KEY=

# NIST NVD API (free — 50 req/30s with key): https://nvd.nist.gov/developers/request-an-api-key
# Greatly improves CVE enrichment quality.
NVD_API_KEY=

# ── Private MISP instance (optional) ────────────────────────────────
MISP_URL=
MISP_API_KEY=

# ── API security ────────────────────────────────────────────────────
# Bearer token for the REST API. Leave empty to run without auth (dev only).
TIPL_API_TOKEN=

# ── Storage ─────────────────────────────────────────────────────────
TIPL_DB_PATH=data/threat_intel.db

# ── Logging ─────────────────────────────────────────────────────────
TIPL_LOG_LEVEL=INFO
